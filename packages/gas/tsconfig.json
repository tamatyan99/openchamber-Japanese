{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "types": ["google-apps-script"],
    "module": "None",
    "moduleDetection": "force",
    "isolatedModules": false,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "build.mjs"]
}
